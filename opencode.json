{
  "$schema": "https://opencode.ai/schema.json",
  "templates": {
    "nestjs": {
      "source": "github:openclaw/opencode-templates#nestjs",
      "variables": {
        "specPath": "../specs/openspec/changes/{feature}/02-openapi.yaml",
        "schemaPath": "../specs/openspec/changes/{feature}/03-schema.prisma"
      }
    }
  },
  "generate": {
    "output": "./src/modules",
    "overwrite": false,
    "dryRun": false
  }
}
